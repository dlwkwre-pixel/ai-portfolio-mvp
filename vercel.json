    {
      "path": "/api/cron/email-digest",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/generate-scenarios",
      "schedule": "0 6 * * *"
    },
    {
      "path": "/api/cron/contribution-reminders",
      "schedule": "0 14 * * *"
    },
    {
      "path": "/api/cron/dividend-reminders",
      "schedule": "0 15 * * *"
    }
  ]
}
